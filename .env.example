# ==========================================
# Configuración del Agente IIBB - Cloud Ready
# ==========================================

# 🔑 LLM API KEYS
# Obtener en: https://aistudio.google.com/
GOOGLE_API_KEY=tu_clave_aqui

# 📂 CONFIGURACIÓN DE BASE DE DATOS (SQLAlchemy)
# Por defecto se usa SQLite local (un archivo casos_db.db)
# Para usar Azure SQL, descomentar y configurar la siguiente variable:
# DATABASE_URL=mssql+pyodbc://usuario:password@tu-servidor.database.windows.net/tu-db?driver=ODBC+Driver+17+for+SQL+Server
DATABASE_URL=sqlite:///memory/casos_db.db

# 🧠 CONFIGURACIÓN DEL AGENTE
MODEL_NAME=gemini-1.5-flash-latest
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ⚖️ PARÁMETROS FISCALES
PROVINCIA_DEFAULT=bsas
ANIO_FISCAL_DEFAULT=2026
